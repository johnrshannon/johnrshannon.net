---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>John Shannon</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="desktop">
      <div class="window">
        <div class="titlebar">
          <div class="dots">
            <span class="dot dot-close"></span>
            <span class="dot dot-min"></span>
            <span class="dot dot-max"></span>
          </div>
          <span class="titlebar-label">john@shannon: ~</span>
        </div>
        <div class="terminal" id="terminal">
          <div id="output"></div>
          <div class="input-row" id="inputRow">
            <span class="prompt">john@shannon ~ %&nbsp;</span>
            <input
              type="text"
              id="cmdInput"
              autocomplete="off"
              autocorrect="off"
              autocapitalize="none"
              spellcheck="false"
            />
            <span class="cursor" id="cursor"></span>
          </div>
        </div>
      </div>
      <div class="suggestions" id="suggestions">
        <span class="suggestions-label">try →</span>
        <button data-cmd="whoami">whoami</button>
        <button data-cmd="cat about.txt">cat about.txt</button>
        <button data-cmd="ls projects/">ls projects/</button>
        <button data-cmd="cat skills.txt">cat skills.txt</button>
        <button data-cmd="cat contact.txt">cat contact.txt</button>
        <button data-cmd="help">help</button>
      </div>
    </div>
  </body>
</html>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #080808;
    --win-bg: #0d0d0d;
    --titlebar: #161616;
    --border: #242424;
    --text: #e8e8e8;
    --muted: #555;
    --accent: #6ee7b7;
    --prompt: #4a9eff;
    --error: #f87171;
    --font: 'JetBrains Mono', monospace;
  }

  html, body {
    height: 100%;
    background: var(--bg);
    font-family: var(--font);
    -webkit-font-smoothing: antialiased;
  }

  .desktop {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    gap: 1.25rem;
  }

  /* Window chrome */
  .window {
    width: 100%;
    max-width: 780px;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.03),
      0 32px 80px rgba(0,0,0,0.6),
      0 0 120px rgba(110, 231, 183, 0.03);
  }

  .titlebar {
    background: var(--titlebar);
    height: 40px;
    display: flex;
    align-items: center;
    padding: 0 1rem;
    gap: 0.75rem;
    border-bottom: 1px solid var(--border);
    user-select: none;
  }

  .dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-close  { background: #ff5f57; }
  .dot-min    { background: #febc2e; }
  .dot-max    { background: #28c840; }

  .titlebar-label {
    font-size: 0.75rem;
    color: var(--muted);
    flex: 1;
    text-align: center;
    margin-right: 54px; /* offset the dots */
  }

  /* Terminal body */
  .terminal {
    background: var(--win-bg);
    padding: 1.25rem 1.5rem;
    min-height: 420px;
    max-height: 60vh;
    overflow-y: auto;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--text);
    scroll-behavior: smooth;
  }

  .terminal::-webkit-scrollbar {
    width: 4px;
  }

  .terminal::-webkit-scrollbar-track {
    background: transparent;
  }

  .terminal::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 2px;
  }

  /* Output lines */
  #output {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .line-cmd {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .line-prompt {
    color: var(--prompt);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .line-cmd-text {
    color: var(--accent);
  }

  .line-output {
    color: var(--text);
    margin-bottom: 1rem;
  }

  .line-muted {
    color: var(--muted);
  }

  .line-accent {
    color: var(--accent);
  }

  .line-error {
    color: var(--error);
  }

  /* Input row */
  .input-row {
    display: flex;
    align-items: center;
    margin-top: 0.25rem;
  }

  .prompt {
    color: var(--prompt);
    white-space: nowrap;
    flex-shrink: 0;
  }

  #cmdInput {
    background: transparent;
    border: none;
    outline: none;
    color: var(--accent);
    font-family: var(--font);
    font-size: 0.875rem;
    flex: 1;
    caret-color: var(--accent);
    width: 100%;
  }

  /* Suggestions */
  .suggestions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 780px;
    width: 100%;
  }

  .suggestions-label {
    font-family: var(--font);
    font-size: 0.75rem;
    color: var(--muted);
  }

  .suggestions button {
    font-family: var(--font);
    font-size: 0.75rem;
    padding: 0.3rem 0.75rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--muted);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .suggestions button:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 600px) {
    .terminal {
      font-size: 0.8rem;
      padding: 1rem;
      max-height: 55vh;
    }

    .titlebar-label {
      font-size: 0.7rem;
    }
  }
</style>

<script>
  const output = document.getElementById('output')!;
  const inputRow = document.getElementById('inputRow')!;
  const cmdInput = document.getElementById('cmdInput') as HTMLInputElement;
  const terminal = document.getElementById('terminal')!;

  const PROMPT = 'john@shannon ~ %';

  const commands: Record<string, string[]> = {
    whoami: [
      '<span class="line-accent">john shannon</span>',
      '<span class="line-muted">software engineer · colorado</span>',
      '',
      'data infrastructure, kubernetes, ci/cd, cloud.',
      'the stuff that makes everything else not fall over.',
    ],

    'cat about.txt': [
      'Born 1987. Based in Colorado since 2014.',
      '',
      'I work at the intersection of data engineering and platform',
      'infrastructure — containers, pipelines, cloud. The unglamorous',
      'but important stuff that keeps systems running in production.',
      '',
      'Outside of work: guitar (badly), cooking (ambitiously),',
      'flossing (religiously). Cancer survivor. Math enthusiast.',
      'Generally fine.',
    ],

    'ls projects/': [
      '<span class="line-muted">total 3</span>',
      '<span class="line-accent">drwxr-xr-x</span>  project-one/',
      '<span class="line-accent">drwxr-xr-x</span>  project-two/',
      '<span class="line-accent">drwxr-xr-x</span>  project-three/',
      '',
      '<span class="line-muted">// real projects coming soon</span>',
    ],

    'cat skills.txt': [
      '<span class="line-muted">languages    </span>  Python · Bash · SQL · TypeScript',
      '<span class="line-muted">cloud        </span>  AWS · Terraform · Ansible',
      '<span class="line-muted">containers   </span>  Docker · Kubernetes · Helm',
      '<span class="line-muted">data         </span>  PostgreSQL · dbt · Spark',
      '<span class="line-muted">ci/cd        </span>  GitHub Actions · ArgoCD · Jenkins',
      '<span class="line-muted">os           </span>  Linux (obviously)',
    ],

    'cat contact.txt': [
      '<span class="line-muted">email   </span>  john.ryland.shannon@gmail.com',
      '<span class="line-muted">github  </span>  <a href="https://github.com/johnrshannon" target="_blank" style="color:var(--accent);text-decoration:none">github.com/johnrshannon ↗</a>',
    ],

    help: [
      '<span class="line-muted">available commands:</span>',
      '',
      '  whoami           who is this guy',
      '  cat about.txt    the longer version',
      '  ls projects/     things i\'ve built',
      '  cat skills.txt   technologies i actually use',
      '  cat contact.txt  get in touch',
      '  clear            clean slate',
      '',
      '<span class="line-muted">// or just click the suggestions below</span>',
    ],

    clear: [],

    // easter eggs
    sudo: [
      '<span class="line-error">permission denied.</span>',
      '<span class="line-muted">nice try.</span>',
    ],
    'rm -rf /': [
      '<span class="line-error">absolutely not.</span>',
    ],
    'rm -rf *': [
      '<span class="line-error">absolutely not.</span>',
    ],
    'git log': [
      '<span class="line-muted">commit</span> <span class="line-accent">a1b2c3d</span> — moved to colorado, figured it out',
      '<span class="line-muted">commit</span> <span class="line-accent">f4e5d6c</span> — beat cancer, resumed normal operations',
      '<span class="line-muted">commit</span> <span class="line-accent">7890abc</span> — switched to mechanical keyboard, no going back',
      '<span class="line-muted">commit</span> <span class="line-accent">def0123</span> — learned kubernetes the hard way',
      '<span class="line-muted">commit</span> <span class="line-accent">456789f</span> — initial commit: born 1987',
    ],
    'git log --oneline': [
      '<span class="line-accent">a1b2c3d</span> moved to colorado, figured it out',
      '<span class="line-accent">f4e5d6c</span> beat cancer, resumed normal operations',
      '<span class="line-accent">7890abc</span> switched to mechanical keyboard, no going back',
      '<span class="line-accent">def0123</span> learned kubernetes the hard way',
      '<span class="line-accent">456789f</span> initial commit: born 1987',
    ],
    'ls -la': [
      '<span class="line-muted">drwxr-xr-x</span>  about.txt',
      '<span class="line-muted">drwxr-xr-x</span>  skills.txt',
      '<span class="line-muted">drwxr-xr-x</span>  contact.txt',
      '<span class="line-muted">drwxr-xr-x</span>  projects/',
      '<span class="line-muted">-rw-------</span>  .secrets  <span class="line-muted">(nice try)</span>',
    ],
  };

  function appendLine(html: string, className = '') {
    const div = document.createElement('div');
    div.innerHTML = html;
    if (className) div.className = className;
    output.appendChild(div);
  }

  function appendCommandLine(cmd: string) {
    const div = document.createElement('div');
    div.className = 'line-cmd';
    div.innerHTML = `<span class="line-prompt">${PROMPT} %</span><span class="line-cmd-text">${cmd}</span>`;
    output.appendChild(div);
  }

  function scrollToBottom() {
    terminal.scrollTop = terminal.scrollHeight;
  }

  function runCommand(cmd: string) {
    const trimmed = cmd.trim().toLowerCase();

    appendCommandLine(cmd.trim());

    if (trimmed === 'clear') {
      output.innerHTML = '';
      scrollToBottom();
      return;
    }

    const result = commands[trimmed];

    if (result === undefined) {
      appendLine(
        `<span class="line-error">command not found: ${cmd.trim()}</span><br><span class="line-muted">type 'help' to see what's available</span>`,
        'line-output'
      );
    } else {
      const block = document.createElement('div');
      block.className = 'line-output';
      block.innerHTML = result.join('\n');
      output.appendChild(block);
    }

    scrollToBottom();
  }

  // Typewriter intro
  async function typewriter(text: string, el: HTMLElement, speed = 30): Promise<void> {
    for (const char of text) {
      el.textContent += char;
      await new Promise(r => setTimeout(r, speed));
    }
  }

  async function intro() {
    inputRow.style.display = 'none';

    const lines = [
      { text: `${PROMPT} % ssh john@shannon.net`, cls: 'line-accent', delay: 0 },
      { text: 'Connected.', cls: 'line-muted', delay: 400 },
      { text: '', cls: '', delay: 200 },
      { text: `Last login: ${new Date().toDateString()}`, cls: 'line-muted', delay: 100 },
      { text: '', cls: '', delay: 100 },
      { text: "Hey. I'm John.", cls: '', delay: 300 },
      { text: "Type a command below, or click a suggestion.", cls: 'line-muted', delay: 100 },
      { text: '', cls: '', delay: 200 },
    ];

    for (const line of lines) {
      await new Promise(r => setTimeout(r, line.delay));
      const div = document.createElement('div');
      div.className = line.cls;
      output.appendChild(div);
      await typewriter(line.text, div, line.text.startsWith(PROMPT) ? 18 : 25);
      scrollToBottom();
    }

    inputRow.style.display = 'flex';
    cmdInput.focus();
  }

  // Input handling
  const history: string[] = [];
  let historyIndex = -1;

  cmdInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const val = cmdInput.value;
      if (!val.trim()) return;
      history.unshift(val);
      historyIndex = -1;
      cmdInput.value = '';
      runCommand(val);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (historyIndex < history.length - 1) {
        historyIndex++;
        cmdInput.value = history[historyIndex];
      }
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (historyIndex > 0) {
        historyIndex--;
        cmdInput.value = history[historyIndex];
      } else {
        historyIndex = -1;
        cmdInput.value = '';
      }
    }
  });

  // Suggestion buttons
  document.querySelectorAll('.suggestions button').forEach((btn) => {
    btn.addEventListener('click', () => {
      const cmd = (btn as HTMLElement).dataset.cmd ?? '';
      cmdInput.value = '';
      runCommand(cmd);
      cmdInput.focus();
    });
  });

  // Click anywhere in terminal to focus input
  terminal.addEventListener('click', () => cmdInput.focus());

  intro();
</script>
