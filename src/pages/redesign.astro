  // ── Output helpers ───────────────────────────────────────────────
  function appendLine(html: string, cls = '') {
    const d = document.createElement('div');
    d.innerHTML = html;
    if (cls) d.className = cls;
    outputEl.appendChild(d);
  }

  function appendCommandLine(cmd: string) {
    const d = document.createElement('div');
    d.className = 'line-cmd';
    d.innerHTML = `<span class="line-prompt">john@shannon ${currentDir} %</span><span class="line-cmd-text">&nbsp;${cmd}</span>`;
    outputEl.appendChild(d);
  }

  function appendOutput(lines: string[]) {
    const block = document.createElement('div');
    block.className = 'line-output';
    block.innerHTML = lines.join('\n');
    outputEl.appendChild(block);
  }

  function scrollBottom() {
    terminal.scrollTop = terminal.scrollHeight;
  }

  // ── Vim ──────────────────────────────────────────────────────────
  let vimMode = 'normal';
  let vimCmdBuffer = '';
  let vimCurrentFile = '';

  function openVim(filename: string) {
    const content = projectFiles[`${currentDir}/${filename}`] ?? files[filename];
    if (!content) {
      appendOutput([`<span class="line-error">vim: ${filename}: No such file or directory</span>`]);
      return;
    }

    vimCurrentFile = filename;
    vimMode = 'normal';
    vimCmdBuffer = '';

    // Render lines with numbers
    vimContent.innerHTML = '';
    content.forEach((line, i) => {
      const row = document.createElement('div');
      row.className = 'vim-line';
      row.innerHTML = `<span class="vim-linenum">${i + 1}</span><span class="vim-linetext">${line || ' '}</span>`;
      vimContent.appendChild(row);
    });
    // Tilde lines to fill space
    for (let i = 0; i < 8; i++) {
      const t = document.createElement('div');
      t.className = 'vim-tilde';
      t.textContent = '~';
      vimContent.appendChild(t);
    }

    vimFilename.textContent = `"${filename}" ${content.length}L`;
    vimModeLabel.textContent = '-- NORMAL --';
    vimCmdLine.textContent = '';
    vimOverlay.classList.add('active');
    cmdInput.focus();
  }

  function closeVim() {
    vimOverlay.classList.remove('active');
    vimMode = 'normal';
    vimCmdBuffer = '';
    vimCmdLine.textContent = '';
    cmdInput.focus();
  }

  function handleVimKey(e: KeyboardEvent) {
    e.preventDefault();

    if (vimMode === 'normal') {
      if (e.key === 'i') {
        vimMode = 'insert';
        vimModeLabel.textContent = '-- INSERT --';
        vimCmdLine.textContent = '';
      } else if (e.key === ':') {
        vimMode = 'command';
        vimCmdBuffer = ':';
        vimCmdLine.textContent = ':';
      } else if (e.key === 'Escape') {
        vimCmdLine.textContent = '';
      }
    } else if (vimMode === 'insert') {
      if (e.key === 'Escape') {
        vimMode = 'normal';
        vimModeLabel.textContent = '-- NORMAL --';
        vimCmdLine.textContent = '';
      }
    } else if (vimMode === 'command') {
      if (e.key === 'Escape') {
        vimMode = 'normal';
        vimCmdBuffer = '';
        vimCmdLine.textContent = '';
      } else if (e.key === 'Enter') {
        const cmd = vimCmdBuffer.slice(1).trim();
        if (cmd === 'q' || cmd === 'q!' || cmd === 'wq!') {
          closeVim();
        } else if (cmd === 'wq' || cmd === 'w') {
          vimCmdLine.textContent = `E45: 'readonly' option is set (add ! to override)`;
          vimMode = 'normal';
          vimCmdBuffer = '';
        } else {
          vimCmdLine.textContent = `E492: Not an editor command: ${cmd}`;
          vimMode = 'normal';
          vimCmdBuffer = '';
        }
      } else if (e.key === 'Backspace') {
        if (vimCmdBuffer.length > 1) {
          vimCmdBuffer = vimCmdBuffer.slice(0, -1);
          vimCmdLine.textContent = vimCmdBuffer;
        } else {
          vimMode = 'normal';
          vimCmdBuffer = '';
          vimCmdLine.textContent = '';
        }
      } else if (e.key.length === 1) {
        vimCmdBuffer += e.key;
        vimCmdLine.textContent = vimCmdBuffer;
      }
    }
  }

  // ── ls clickable entries ─────────────────────────────────────────
  function makeLsLines(lines: string[], colors: Record<string, string> = {}): string[] {
    return lines.map(line => line.replace(/(\s{2,})(\S+\/?)$/, (_, spaces, name) => {
      const isDir = name.endsWith('/');
      const cmd = isDir ? `cd ${name.slice(0, -1)}` : `cat ${name}`;
      const color = colors[name] ?? (isDir ? 'var(--prompt)' : '');
      const style = color ? ` style="color:${color}"` : '';
      return `${spaces}<span class="ls-clickable" data-cmd="${cmd}"${style}>${name}</span>`;
    }));
  }

  // ── README renderer ──────────────────────────────────────────────
  function renderReadme(lines: string[]): string[] {
    return lines.map(line => {
      if (line.startsWith('# ')) {
        return `<span style="color:var(--accent);font-weight:700;font-size:1.1em;">${line.slice(2)}</span>`;
      }
      if (line.match(/^(stack|status)\s{2,}/)) {
        const match = line.match(/^(\S+)(\s{2,})(.+)$/);
        if (match) return `<span class="line-muted">${match[1]}</span>${match[2]}<span style="color:var(--prompt)">${match[3]}</span>`;
      }
      return line;
    });
  }

  // ── Fake apt install ─────────────────────────────────────────────
  async function fakeAptInstall(pkg: string) {
    const steps = [
      'Reading package lists... Done',
      'Building dependency tree... Done',
      'Reading state information... Done',
      `The following NEW packages will be installed:\n  ${pkg}`,
      '0 upgraded, 1 newly installed, 0 to remove and 0 not upgraded.',
      `Unpacking ${pkg} ...`,
      `Setting up ${pkg} ...`,
      `<span class="line-accent">${pkg} installed successfully.</span>`,
      '<span class="line-muted">// just kidding. nothing actually installed.</span>',
    ];
    for (const step of steps) {
      await new Promise(r => setTimeout(r, 180));
      const div = document.createElement('div');
      div.className = 'line-output';
      div.innerHTML = step;
      outputEl.appendChild(div);
      scrollBottom();
    }
  }

  // ── Command runner ───────────────────────────────────────────────
  function runCommand(raw: string) {
    const cmd = raw.trim();
    const lower = cmd.toLowerCase();

    appendCommandLine(cmd);

    // clear
    if (lower === 'clear') {
      outputEl.innerHTML = '';
      scrollBottom();
      return;
    }

    // history
    if (lower === 'history') {
      if (history.length === 0) {
        appendOutput(['<span class="line-muted">no commands in history</span>']);
      } else {
        appendOutput([...history].reverse().map((c, i) => `  ${i + 1}  ${c}`));
      }
      scrollBottom();
      return;
    }

    // pwd
    if (lower === 'pwd') {
      appendOutput([currentDir === '~' ? '/home/john' : '/home/john/projects']);
      scrollBottom();
      return;
    }

    // date
    if (lower === 'date') {
      appendOutput([new Date().toString()]);
      scrollBottom();
      return;
    }

    // echo
    if (lower === 'echo' || lower.startsWith('echo ')) {
      appendOutput([cmd.slice(5)]);
      scrollBottom();
      return;
    }

    // which
    if (lower.startsWith('which ')) {
      const whichCmd = lower.slice(6).trim();
      const paths: Record<string, string> = {
        python: '/usr/bin/python3', python3: '/usr/bin/python3',
        bash: '/bin/bash', zsh: '/bin/zsh', sh: '/bin/sh',
        vim: '/usr/bin/vim', vi: '/usr/bin/vim',
        git: '/usr/bin/git', node: '/usr/local/bin/node',
        npm: '/usr/local/bin/npm', docker: '/usr/bin/docker',
        kubectl: '/usr/local/bin/kubectl', terraform: '/usr/local/bin/terraform',
        ansible: '/usr/bin/ansible', aws: '/usr/local/bin/aws',
        curl: '/usr/bin/curl', wget: '/usr/bin/wget',
        grep: '/usr/bin/grep', ls: '/bin/ls', cat: '/bin/cat',
        less: '/usr/bin/less', more: '/usr/bin/more',
      };
      appendOutput(paths[whichCmd]
        ? [paths[whichCmd]]
        : [`<span class="line-error">which: no ${whichCmd} in (/usr/local/bin:/usr/bin:/bin:/home/john/.local/bin)</span>`]
      );
      scrollBottom();
      return;
    }

    // ping
    if (lower.startsWith('ping ')) {
      const host = cmd.slice(5).trim().toLowerCase();
      const special: Record<string, string[]> = {
        localhost: [
          'PING localhost (127.0.0.1): 56 data bytes',
          '64 bytes from 127.0.0.1: icmp_seq=0 ttl=64 time=0.042 ms',
          '64 bytes from 127.0.0.1: icmp_seq=1 ttl=64 time=0.038 ms',
          '--- localhost ping statistics ---',
          '2 packets transmitted, 2 received, 0% packet loss',
        ],
        production: [
          'PING production (10.0.1.42): 56 data bytes',
          'Request timeout for icmp_seq 0',
          'Request timeout for icmp_seq 1',
          'Request timeout for icmp_seq 2',
          '--- production ping statistics ---',
          '<span class="line-error">3 packets transmitted, 0 received, 100% packet loss</span>',
          '<span class="line-muted">// as expected</span>',
        ],
      };
      if (special[host]) {
        appendOutput(special[host]);
      } else {
        const ip = `${~~(Math.random()*200+20)}.${~~(Math.random()*255)}.${~~(Math.random()*255)}.${~~(Math.random()*255)}`;
        appendOutput([
          `PING ${host} (${ip}): 56 data bytes`,
          `64 bytes from ${ip}: icmp_seq=0 ttl=117 time=${(Math.random()*20+5).toFixed(1)} ms`,
          `64 bytes from ${ip}: icmp_seq=1 ttl=117 time=${(Math.random()*20+5).toFixed(1)} ms`,
          `64 bytes from ${ip}: icmp_seq=2 ttl=117 time=${(Math.random()*20+5).toFixed(1)} ms`,
          '^C',
          `--- ${host} ping statistics ---`,
          '3 packets transmitted, 3 received, 0% packet loss',
        ]);
      }
      scrollBottom();
      return;
    }

    // curl
    if (lower.startsWith('curl ')) {
      const url = cmd.slice(5).trim().toLowerCase();
      if (url.includes('wttr.in') || url.includes('weather')) {
        appendOutput([
          'Weather for Denver, CO:',
          '',
          '    \\  /  Partly Cloudy',
          '  _ /"".-.     55 °F',
          '    \\_(   ).   \u2192 12 mph',
          '    /(___(__)  10 mi visibility',
          '',
          '<span class="line-muted">// good hiking weather. go outside.</span>',
        ]);
      } else if (url.includes('icanhazip') || url.includes('ifconfig.me')) {
        appendOutput(['192.168.1.42']);
      } else {
        appendOutput([`<span class="line-error">curl: (7) Failed to connect to ${url.replace(/^https?:\/\//, '')}: Connection refused</span>`]);
      }
      scrollBottom();
      return;
    }

    // man
    if (lower.startsWith('man ')) {
      const manCmd = lower.slice(4).trim();
      const pages: Record<string, string[]> = {
        ls: [
          'LS(1)                     User Commands                     LS(1)',
          '', 'NAME', '       ls — list directory contents',
          '', 'SYNOPSIS', '       ls [-la] [directory]',
          '', 'DESCRIPTION',
          '       List files in the current directory.',
          '       -l    use long listing format',
          '       -a    include hidden files',
        ],
        vim: [
          'VIM(1)                    User Commands                     VIM(1)',
          '', 'NAME', '       vim — Vi IMproved, a programmer\'s text editor',
          '', 'SYNOPSIS', '       vim [file]',
          '', 'DESCRIPTION',
          '       A highly configurable text editor.',
          '       :q    quit           i     insert mode',
          '       :wq   write & quit   Esc   normal mode',
          '', '<span class="line-muted">// good luck getting out</span>',
        ],
        john: [
          'JOHN(1)                   User Commands                     JOHN(1)',
          '', 'NAME', '       john — sr. site reliability engineer',
          '', 'SYNOPSIS', '       john [--guitar] [--cook] [--floss]',
          '', 'DESCRIPTION',
          '       Keeps software running in production.',
          '       Based in Colorado. Generally reliable.',
          '', 'OPTIONS',
          '       --guitar    plays guitar, results may vary',
          '       --cook      cooks experimentally, usually edible',
          '       --floss     no exceptions',
          '', 'SEE ALSO', '       cat about.txt, cat contact.txt',
        ],
        git: [
          'GIT(1)                    User Commands                     GIT(1)',
          '', 'NAME', '       git — the stupid content tracker',
          '', 'COMMON COMMANDS',
          '       git log           show commit history',
          '       git log --oneline one line per commit',
          '', '<span class="line-muted">try: git log, git log --oneline</span>',
        ],
        kubectl: [
          'KUBECTL(1)                User Commands                  KUBECTL(1)',
          '', 'NAME', '       kubectl — kubernetes cluster manager',
          '', 'COMMON COMMANDS',
          '       kubectl get pods         list running pods',
          '       kubectl get nodes        list cluster nodes',
          '       kubectl get deployments  list deployments',
        ],
      };
      appendOutput(pages[manCmd]
        ?? [`<span class="line-error">No manual entry for ${manCmd}</span>`]
      );
      scrollBottom();
      return;
    }

    // apt install
    if (lower.startsWith('apt install') || lower.startsWith('apt-get install')) {
      const pkg = cmd.split(' ').slice(2).join(' ') || '<package>';
      fakeAptInstall(pkg);
      return;
    }

    // cd
    if (lower === 'cd' || lower === 'cd ~') {
      setDir('~');
      scrollBottom();
      return;
    }
    if (lower === 'cd projects/' || lower === 'cd projects') {
      if (currentDir !== '~') {
        appendOutput(['<span class="line-error">no such directory</span>']);
      } else {
        setDir('~/projects');
        appendOutput(makeLsLines(dirContents['~/projects'], fileColors['~/projects'] ?? {}));
      }
      scrollBottom();
      return;
    }
    const cdHomeDirMatch = lower.match(/^cd (dotfiles|scripts|oncall)\/?$/);
    if (cdHomeDirMatch) {
      if (currentDir !== '~') {
        appendOutput([`<span class="line-error">cd: ${cdHomeDirMatch[1]}: No such file or directory</span>`]);
      } else {
        const newDir = `~/${cdHomeDirMatch[1]}`;
        setDir(newDir);
        appendOutput(makeLsLines(dirContents[newDir], fileColors[newDir] ?? {}));
      }
      scrollBottom();
      return;
    }
    const cdProjectMatch = lower.match(/^cd (sentry-gate|pipeline-delta|burndown)\/?$/);
    if (cdProjectMatch) {
      if (currentDir !== '~/projects') {
        appendOutput([`<span class="line-error">cd: ${cdProjectMatch[1]}: No such file or directory</span>`]);
      } else {
        const newDir = `~/projects/${cdProjectMatch[1]}`;
        setDir(newDir);
        appendOutput(makeLsLines(dirContents[newDir], fileColors[newDir] ?? {}));
      }
      scrollBottom();
      return;
    }
    if (lower === 'cd ..') {
      if (currentDir.startsWith('~/projects/')) {
        setDir('~/projects');
        appendOutput(makeLsLines(dirContents['~/projects'], fileColors['~/projects'] ?? {}));
      } else if (currentDir !== '~') {
        setDir('~');
        appendOutput(makeLsLines(dirContents['~'], fileColors['~'] ?? {}));
      }
      scrollBottom();
      return;
    }
    if (lower.startsWith('cd ')) {
      appendOutput([`<span class="line-error">cd: ${cmd.slice(3)}: No such file or directory</span>`]);
      scrollBottom();
      return;
    }

    // ls
    if (lower === 'ls' || lower === 'ls -la' || lower === 'ls -l') {
      const contents = dirContents[currentDir] ?? [];
      const showHidden = lower.includes('-la') || lower.includes('-a');
      const filtered = showHidden ? contents : contents.filter(l => !l.includes('.secrets'));
      appendOutput(makeLsLines(filtered, fileColors[currentDir] ?? {}));
      scrollBottom();
      return;
    }

    // cat / less / more
    const catMatch = lower.match(/^(?:cat|less|more)\s+(.+)$/);
    if (catMatch) {
      const filename = cmd.slice(cmd.indexOf(' ') + 1).trim();
      const fullPath = `${currentDir}/${filename}`;
      const content = projectFiles[fullPath] ?? files[filename];
      if (filename === '.secrets') {
        appendOutput(['<span class="line-error">permission denied.</span>']);
      } else if (!content) {
        appendOutput([`<span class="line-error">${catMatch[0].startsWith('cat') ? 'cat' : catMatch[0].startsWith('less') ? 'less' : 'more'}: ${filename}: No such file or directory</span>`]);
      } else {
        const isPaged = lower.startsWith('less') || lower.startsWith('more');
        const rendered = filename.endsWith('.md') ? renderReadme(content) : content;
        appendOutput([...rendered, ...(isPaged ? ['', '<span class="line-muted">-- END --</span>'] : [])]);
      }
      scrollBottom();
      return;
    }

    // vi / vim
    const vimMatch = lower.match(/^(?:vi|vim)\s+(.+)$/);
    if (vimMatch) {
      const filename = vimMatch[1].trim();
      if (staticCmds[`vim ${filename}`]) {
        appendOutput(staticCmds[`vim ${filename}`]);
      } else {
        openVim(filename);
      }
      scrollBottom();
      return;
    }

    // static commands
    const result = staticCmds[lower];
    if (result !== undefined) {
      appendOutput(result);
      scrollBottom();
      return;
    }

    // not found
    appendOutput([`<span class="line-error">command not found: ${cmd}</span><br><span class="line-muted">type 'help' to see what's available</span>`]);
    scrollBottom();
  }

  // ── Input handling ───────────────────────────────────────────────
  const history: string[] = [];
  let historyIndex = -1;

  const baseCompletions = [
    'whoami', 'help', 'clear', 'history', 'pwd', 'date',
    'ls', 'ls -la',
    'git log', 'git log --oneline',
    'hostname', 'uname -a', 'uptime', 'env', 'ps aux', 'df -h', 'free -h',
    'kubectl', 'kubectl get pods', 'kubectl get nodes', 'kubectl get deployments',
    'ping localhost', 'ping production',
    'curl wttr.in', 'curl icanhazip.com',
    'man vim', 'man git', 'man john', 'man kubectl', 'man ls',
    'which vim', 'which python', 'which kubectl', 'which terraform',
    'echo hello', 'apt install vim',
    'sudo', 'nano', 'brew', 'exit',
  ];

  function getCompletions(): string[] {
    if (currentDir === '~') {
      return [
        ...baseCompletions,
        'cd projects', 'cd dotfiles', 'cd scripts', 'cd oncall', 'cd ~',
        'cat about.txt', 'cat skills.txt', 'cat TODO.md', 'cat reads.txt', 'cat Makefile', 'cat .vimrc',
        'less about.txt', 'less skills.txt', 'less reads.txt',
        'vim about.txt', 'vim skills.txt', 'vim .vimrc',
      ];
    } else if (currentDir === '~/projects') {
      return [
        ...baseCompletions,
        'cd sentry-gate', 'cd pipeline-delta', 'cd burndown', 'cd ..', 'cd ~',
      ];
    } else if (currentDir.startsWith('~/projects/')) {
      return [
        ...baseCompletions,
        'cat README.md', 'less README.md', 'vim README.md', 'cd ..', 'cd ~',
      ];
    } else if (currentDir === '~/dotfiles') {
      return [
        ...baseCompletions,
        'cat .vimrc', 'cat .zshrc', 'cat .gitconfig', 'cd ..', 'cd ~',
      ];
    } else if (currentDir === '~/scripts') {
      return [
        ...baseCompletions,
        'cat deploy.sh', 'cat backup.sh', 'cat check-services.sh', 'cd ..', 'cd ~',
      ];
    } else if (currentDir === '~/oncall') {
      return [
        ...baseCompletions,
        'cat runbook.md', 'cat postmortem-2023-11.md', 'cat postmortem-2024-03.md', 'cd ..', 'cd ~',
      ];
    }
    return baseCompletions;
  }

  document.addEventListener('keydown', (e) => {
    if (vimOverlay.classList.contains('active')) {
      handleVimKey(e);
    }
  });

  cmdInput.addEventListener('keydown', (e) => {
    if (vimOverlay.classList.contains('active')) return;

    if (e.key === 'Tab') {
      e.preventDefault();
      const val = cmdInput.value.toLowerCase();
      if (!val) return;
      const match = getCompletions().find(c => c.toLowerCase().startsWith(val) && c.toLowerCase() !== val);
      if (match) cmdInput.value = match;
    } else if (e.key === 'Enter') {
      const val = cmdInput.value;
      if (!val.trim()) return;
      history.unshift(val);
      historyIndex = -1;
      cmdInput.value = '';
      runCommand(val);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (historyIndex < history.length - 1) {
        historyIndex++;
        cmdInput.value = history[historyIndex];
      }
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (historyIndex > 0) {
        historyIndex--;
        cmdInput.value = history[historyIndex];
      } else {
        historyIndex = -1;
        cmdInput.value = '';
      }
    }
  });

  // Suggestion buttons
  document.querySelectorAll('.suggestions button').forEach((btn) => {
    btn.addEventListener('click', () => {
      const cmd = (btn as HTMLElement).dataset.cmd ?? '';
      cmdInput.value = '';
      runCommand(cmd);
      cmdInput.focus();
    });
  });

  terminal.addEventListener('click', () => cmdInput.focus());

  outputEl.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('ls-clickable')) {
      e.stopPropagation();
      const cmd = target.dataset.cmd ?? '';
      if (cmd) { runCommand(cmd); cmdInput.focus(); }
    }
  });

  // ── Typewriter intro ─────────────────────────────────────────────
  async function typewriter(text: string, el: HTMLElement, speed = 30): Promise<void> {
    for (const char of text) {
      el.textContent += char;
      await new Promise(r => setTimeout(r, speed));
    }
  }

  async function intro() {
    inputRow.style.display = 'none';

    const PROMPT_STR = 'john@shannon ~ %';
    const lines = [
      { text: `${PROMPT_STR} % ssh john@shannon.net`, cls: 'line-accent', delay: 0 },
      { text: 'Connected.', cls: 'line-muted', delay: 130 },
      { text: '', cls: '', delay: 60 },
      { text: `Last login: ${new Date().toDateString()}`, cls: 'line-muted', delay: 30 },
      { text: '', cls: '', delay: 30 },
      { text: "Type a command, or click a suggestion below.", cls: 'line-muted', delay: 30 },
      { text: '', cls: '', delay: 30 },
    ];

    for (const line of lines) {
      await new Promise(r => setTimeout(r, line.delay));
      const div = document.createElement('div');
      div.className = line.cls;
      outputEl.appendChild(div);
      await typewriter(line.text, div, line.text.startsWith(PROMPT_STR) ? 12 : 16);
      scrollBottom();
    }

    appendOutput(makeLsLines(dirContents['~'], fileColors['~'] ?? {}));
    scrollBottom();

    inputRow.style.display = 'flex';
    cmdInput.focus();
  }

  intro();
</script>
