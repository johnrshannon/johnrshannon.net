---
import { execSync } from 'child_process';

let commitHash = 'unknown';
let commitTime = 'unknown';

try {
  commitHash = execSync('git rev-parse --short HEAD').toString().trim();
  commitTime = execSync('git log -1 --format=%cd --date=format:"%Y-%m-%d %H:%M UTC"').toString().trim();
} catch (e) {}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>John Shannon</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="desktop">
      <div class="contact-bar">
        <span class="contact-label">reach me</span>
        <a href="mailto:john.ryland.shannon@gmail.com">john.ryland.shannon@gmail.com</a>
        <span class="contact-sep">·</span>
        <a href="https://github.com/johnrshannon" target="_blank" rel="noopener">github.com/johnrshannon</a>
        <span class="contact-sep">·</span>
        <a href="https://www.linkedin.com/in/john-shannon-1703878b/" target="_blank" rel="noopener">linkedin</a>
      </div>
      <div class="window">
        <div class="titlebar">
          <div class="dots">
            <span class="dot dot-close"></span>
            <span class="dot dot-min"></span>
            <span class="dot dot-max"></span>
          </div>
          <span class="titlebar-label" id="titlebarLabel">john@shannon: ~</span>
        </div>
        <div class="terminal" id="terminal">
          <div id="output"></div>
          <div class="input-row" id="inputRow">
            <span class="prompt" id="prompt">john@shannon ~ %&nbsp;</span>
            <input
              type="text"
              id="cmdInput"
              autocomplete="off"
              autocorrect="off"
              autocapitalize="none"
              spellcheck="false"
            />
          </div>
        </div>
        <div id="buildInfo" data-hash={commitHash} data-time={commitTime} style="display:none"></div>
    <!-- Vim overlay -->
        <div id="vimOverlay" class="vim-overlay">
          <div id="vimContent" class="vim-content"></div>
          <div class="vim-statusbar">
            <span id="vimFilename"></span>
            <span id="vimModeLabel">-- NORMAL --</span>
          </div>
          <div id="vimCmdLine" class="vim-cmdline"></div>
        </div>
      </div>
      <div class="suggestions" id="suggestions">
        <span class="suggestions-label">try →</span>
        <button data-cmd="whoami">whoami</button>
        <button data-cmd="man john">man john</button>
        <button data-cmd="cd projects">cd projects</button>
        <button data-cmd="cat skills.txt">cat skills.txt</button>
        <button data-cmd="git log">git log</button>
        <button data-cmd="help">help</button>
      </div>
      <div class="build-info" id="buildFooter"></div>
    </div>
  </body>
</html>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #080d14;
    --win-bg: #0a0f18;
    --titlebar: #0f1520;
    --border: #1e2a3a;
    --text: #e8e8e8;
    --muted: #555;
    --accent: #6ee7b7;
    --prompt: #4a9eff;
    --error: #f87171;
    --font: 'JetBrains Mono', monospace;
  }

  html, body {
    height: 100%;
    background-color: var(--bg);
    background-image: radial-gradient(circle, #1e2a3a 1px, transparent 1px);
    background-size: 28px 28px;
    font-family: var(--font);
    -webkit-font-smoothing: antialiased;
  }

  .desktop {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    gap: 1.25rem;
  }

  /* Window chrome */
  .window {
    width: 100%;
    max-width: 780px;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.03),
      0 32px 80px rgba(0,0,0,0.6),
      0 0 120px rgba(110, 231, 183, 0.03);
  }

  .titlebar {
    background: var(--titlebar);
    height: 40px;
    display: flex;
    align-items: center;
    padding: 0 1rem;
    gap: 0.75rem;
    border-bottom: 1px solid var(--border);
    user-select: none;
    position: relative;
    z-index: 2;
  }

  .dots { display: flex; gap: 6px; }
  .dot { width: 12px; height: 12px; border-radius: 50%; }
  .dot-close  { background: #ff5f57; }
  .dot-min    { background: #febc2e; }
  .dot-max    { background: #28c840; }

  .titlebar-label {
    font-size: 0.75rem;
    color: var(--muted);
    flex: 1;
    text-align: center;
    margin-right: 54px;
  }

  /* Terminal body */
  .terminal {
    background: var(--win-bg);
    padding: 1.25rem 1.5rem;
    min-height: 420px;
    max-height: 60vh;
    overflow-y: auto;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--text);
    scroll-behavior: smooth;
  }

  .terminal::-webkit-scrollbar { width: 4px; }
  .terminal::-webkit-scrollbar-track { background: transparent; }
  .terminal::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  #output {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .line-cmd {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .line-prompt { color: var(--prompt); white-space: nowrap; flex-shrink: 0; }
  .line-cmd-text { color: var(--accent); }
  .line-output { color: var(--text); margin-bottom: 1rem; }
  .line-muted { color: var(--muted); }
  .line-accent { color: var(--accent); }
  .line-error { color: var(--error); }
  :global(.ls-clickable) { cursor: pointer; transition: color 0.15s; }
  :global(.ls-clickable:hover) { color: var(--prompt); }

  .input-row {
    display: flex;
    align-items: center;
    margin-top: 0.25rem;
  }

  .prompt {
    color: var(--prompt);
    white-space: nowrap;
    flex-shrink: 0;
  }

  #cmdInput {
    background: transparent;
    border: none;
    outline: none;
    color: var(--accent);
    font-family: var(--font);
    font-size: 0.875rem;
    flex: 1;
    caret-color: var(--accent);
    width: 100%;
  }

  /* Vim overlay */
  .vim-overlay {
    display: none;
    position: absolute;
    top: 40px;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--win-bg);
    flex-direction: column;
    font-size: 0.875rem;
    font-family: var(--font);
    z-index: 10;
  }

  .vim-overlay.active {
    display: flex;
  }

  .vim-content {
    flex: 1;
    overflow-y: auto;
    padding: 0.25rem 0;
    color: var(--text);
    line-height: 1.7;
  }

  .vim-content::-webkit-scrollbar { width: 4px; }
  .vim-content::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .vim-line {
    display: flex;
    gap: 2rem;
    padding: 0 1rem;
  }

  .vim-linenum {
    color: var(--muted);
    min-width: 2.5rem;
    text-align: right;
    user-select: none;
    flex-shrink: 0;
  }

  .vim-linetext { flex: 1; }

  .vim-tilde {
    padding: 0 1rem;
    color: var(--muted);
  }

  .vim-statusbar {
    background: var(--accent);
    color: #080d14;
    padding: 0.15rem 1rem;
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .vim-cmdline {
    padding: 0.15rem 1rem;
    color: var(--text);
    font-size: 0.875rem;
    min-height: 1.6rem;
    flex-shrink: 0;
  }

  /* Contact bar */
  .contact-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font);
    font-size: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 780px;
    width: 100%;
  }

  .contact-label {
    color: var(--text);
    font-weight: 700;
  }

  .contact-sep {
    color: var(--muted);
  }

  .contact-bar a {
    color: var(--prompt);
    transition: opacity 0.15s;
  }

  .contact-bar a:hover {
    opacity: 0.75;
  }

  /* Suggestions */
  .suggestions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 780px;
    width: 100%;
  }

  .build-info {
    font-family: var(--font);
    font-size: 0.7rem;
    color: var(--muted);
    text-align: center;
    margin-top: 0.25rem;
  }

  .suggestions-label {
    font-family: var(--font);
    font-size: 0.75rem;
    color: var(--muted);
  }

  .suggestions button {
    font-family: var(--font);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.3rem 0.75rem;
    background: transparent;
    border: 1px solid #444;
    border-radius: 6px;
    color: #aaa;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .suggestions button:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 600px) {
    .terminal { font-size: 0.8rem; padding: 1rem; max-height: 55vh; }
    .titlebar-label { font-size: 0.7rem; }
  }
</style>

<script>
